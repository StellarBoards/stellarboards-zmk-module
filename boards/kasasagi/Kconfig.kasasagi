config BOARD_KASASAGI
    select SOC_NRF52840_QIAA
    select ZMK_BOARD_COMPAT if BOARD_KASASAGI_NRF52840_ZMK
    imply RETAINED_MEM if BOARD_KASASAGI_NRF52840_ZMK
    imply RETENTION if BOARD_KASASAGI_NRF52840_ZMK
    imply RETENTION_BOOT_MODE if BOARD_KASASAGI_NRF52840_ZMK
